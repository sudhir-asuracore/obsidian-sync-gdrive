{
  "name": "obsidian-sync-gdrive",
  "version": "1.0.5",
  "description": "Sync your Obsidian vault to Google Drive.",
  "main": "index.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "npx tsc -noEmit && node esbuild.config.mjs production",
    "package": "npm run build && node package.mjs",
    "package:deploy": "npm run package && node scripts/copy-to-obsidian.mjs",
    "watch:deploy": "nodemon --watch src --ext ts,js,json --exec \"npm run package:deploy\"",
    "bridge": "http-server bridge -p 8080",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": [],
  "author": "Sudhir Babu Nakka",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^25.2.3",
    "builtin-modules": "^5.0.0",
    "dotenv": "^17.3.1",
    "esbuild": "0.27.3",
    "http-server": "^14.1.1",
    "nodemon": "^3.1.0",
    "obsidian": "^1.12.0",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3"
  }
}
